{
  "name": "sentry-android-architecture",
  "version": "1.0.0",
  "description": "Sentry Android Security Detection Framework - 完整项目架构定义",

  "project": {
    "name": "Sentry",
    "package": "anti.rusda",
    "type": "android-security-detection",
    "architecture": "java-cpp-hybrid"
  },

  "tech_stack": {
    "android": {
      "min_sdk": 24,
      "target_sdk": 36,
      "compile_sdk": 36,
      "abi": ["arm64-v8a"]
    },
    "build_tools": {
      "agp": "8.13.1",
      "gradle": "8.13",
      "cmake": "3.22.1",
      "ndk": "supported"
    },
    "ui_framework": "Material Design 3",
    "languages": ["Java", "C++", "CMake"]
  },

  "modules": {
    "presentation": {
      "path": "app/src/main/java/anti/rusda",
      "components": [
        {
          "name": "MainActivity",
          "file": "MainActivity.java",
          "type": "Activity",
          "description": "主界面，检测执行和结果展示",
          "native_methods": [
            "nativeDetectFridaThread()",
            "nativeDetectFridaPort()",
            "nativeDetectFridaMemory()",
            "nativeDetectDebugMode()",
            "nativeDetectHook()",
            "nativeGetDetectionDetails()"
          ]
        },
        {
          "name": "SettingsActivity",
          "file": "SettingsActivity.java",
          "type": "Activity",
          "description": "设置界面，主题/语言/功能开关"
        },
        {
          "name": "SentryApp",
          "file": "SentryApp.java",
          "type": "Application",
          "description": "应用入口，语言初始化"
        },
        {
          "name": "LocaleHelper",
          "file": "LocaleHelper.java",
          "type": "Utility",
          "description": "语言切换工具类"
        }
      ]
    },

    "detection_engine": {
      "path": "app/src/main/java/anti/rusda/detector",
      "components": [
        {
          "name": "DetectionManager",
          "file": "DetectionManager.java",
          "type": "Manager",
          "description": "12种检测方法的统一入口",
          "detections": [
            {"id": 1, "name": "Frida Threads", "method": "detectFridaThreads", "status": "DANGER"},
            {"id": 2, "name": "Frida Ports", "method": "detectFridaPorts", "status": "DANGER"},
            {"id": 3, "name": "Memory Signatures", "method": "detectMemorySignatures", "status": "DANGER"},
            {"id": 4, "name": "Named Pipes", "method": "detectNamedPipes", "status": "DANGER"},
            {"id": 5, "name": "Debug Mode", "method": "detectDebugMode", "status": "WARNING"},
            {"id": 6, "name": "Root Detection", "method": "detectRoot", "status": "WARNING"},
            {"id": 7, "name": "Suspicious Files", "method": "detectSuspiciousFiles", "status": "DANGER"},
            {"id": 8, "name": "Ptrace Status", "method": "detectPtraceStatus", "status": "DANGER"},
            {"id": 9, "name": "Emulator Detection", "method": "detectEmulator", "status": "WARNING"},
            {"id": 10, "name": "SELinux Status", "method": "detectSELinuxStatus", "status": "WARNING"},
            {"id": 11, "name": "Library Integrity", "method": "checkLibraryIntegrity", "status": "DANGER"},
            {"id": 12, "name": "Multi-instance", "method": "checkProcessStatus", "status": "WARNING"}
          ]
        },
        {
          "name": "DetectionResult",
          "file": "DetectionResult.java",
          "type": "Model",
          "description": "检测结果数据模型",
          "fields": ["title", "description", "status", "details", "expanded"],
          "status_codes": {
            "STATUS_NORMAL": 0,
            "STATUS_WARNING": 1,
            "STATUS_DANGER": 2
          }
        }
      ]
    },

    "ui_adapter": {
      "path": "app/src/main/java/anti/rusda/ui/adapter",
      "components": [
        {
          "name": "DetectionAdapter",
          "file": "DetectionAdapter.java",
          "type": "Adapter",
          "description": "RecyclerView适配器，展示检测结果卡片"
        }
      ]
    },

    "native_layer": {
      "path": "app/src/main/cpp",
      "library": "libantifrida.so",
      "components": [
        {
          "name": "native-lib",
          "file": "native-lib.cpp",
          "type": "JNI_Bridge",
          "description": "JNI接口层，连接Java与Native"
        },
        {
          "name": "thread_detector",
          "file": "detector/thread_detector.cpp",
          "type": "Detector",
          "description": "线程检测器，扫描/proc/self/task"
        },
        {
          "name": "port_scanner",
          "file": "detector/port_scanner.cpp",
          "type": "Detector",
          "description": "端口扫描器，检测Frida默认端口"
        },
        {
          "name": "memory_scanner",
          "file": "detector/memory_scanner.cpp",
          "type": "Detector",
          "description": "内存扫描器，分析/proc/self/maps"
        },
        {
          "name": "hook_detector",
          "file": "detector/hook_detector.cpp",
          "type": "Detector",
          "description": "Hook检测器，检查内联Hook和PLT/GOT"
        },
        {
          "name": "anti_debug",
          "file": "detector/anti_debug.cpp",
          "type": "Detector",
          "description": "反调试器，检测TracerPid和调试状态"
        },
        {
          "name": "syscall_utils",
          "file": "utils/syscall_utils.cpp",
          "type": "Utility",
          "description": "系统调用工具，直接syscall绕过libc hook"
        }
      ]
    },

    "resources": {
      "layouts": [
        {"name": "activity_main", "file": "activity_main.xml", "type": "Main"},
        {"name": "activity_settings", "file": "activity_settings.xml", "type": "Settings"},
        {"name": "item_detection", "file": "item_detection.xml", "type": "Item"}
      ],
      "strings": [
        {"locale": "en", "file": "values/strings.xml"},
        {"locale": "zh", "file": "values-zh/strings.xml"}
      ],
      "themes": [
        {"name": "Theme.Sentry", "parent": "Theme.Material3.Light"},
        {"name": "Theme.Sentry.Dark", "parent": "Theme.Material3.Dark"}
      ]
    }
  },

  "build_config": {
    "cmake": {
      "file": "app/src/main/cpp/CMakeLists.txt",
      "features": [
        "16KB page alignment (Android 15+)",
        "Symbol visibility hidden",
        "ARM64-v8a optimization"
      ]
    },
    "proguard": {
      "file": "app/proguard-rules.pro",
      "rules": [
        "Keep native methods",
        "Keep detector package",
        "Keep adapter package",
        "Keep Material components"
      ]
    }
  },

  "security_features": [
    "Direct syscall (bypass libc hook)",
    "Custom string/memory functions",
    "Symbol hiding (-fvisibility=hidden)",
    "ProGuard obfuscation",
    "16KB page alignment"
  ],

  "extension_points": {
    "add_detection": [
      "1. Implement in DetectionManager.java",
      "2. Create C++ detector in detector/",
      "3. Add JNI bridge in native-lib.cpp",
      "4. Update strings.xml localization",
      "5. Register in runAllDetections()"
    ],
    "add_language": [
      "1. Create res/values-[code]/strings.xml",
      "2. Copy English strings",
      "3. Translate to target language",
      "4. Add option in SettingsActivity"
    ]
  },

  "dependencies": {
    "material": "com.google.android.material:material:1.12.0",
    "appcompat": "androidx.appcompat:appcompat:1.7.0",
    "recyclerview": "androidx.recyclerview:recyclerview:1.3.2",
    "cardview": "androidx.cardview:cardview:1.0.0",
    "coordinatorlayout": "androidx.coordinatorlayout:coordinatorlayout:1.2.0"
  }
}
